# =========================================================
# Portal Actividad 3 — variables de entorno
# Copiar a `.env` y completar.
# =========================================================

# Entorno
APP_ENV=local
DEBUG=true

# CORS (frontend dev)
# CORS_ORIGINS=["http://localhost:4200"]

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Supabase (dejar vacío para modo degraded — sin Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Singularity / planner
# Ruta al archivo .sif del planner descargado por infra/singularity/pull-planner.sh
SINGULARITY_IMAGE_PATH=
SINGULARITY_PLANNER_NAME=delfi
PLAN_TIMEOUT_SECONDS=1800

# Directorios PDDL (defaults relativos al repo)
# PORTAL_ACT3_PDDL_DIR=./entregables/pddl
# PORTAL_ACT3_PLANS_DIR=./entregables/planes
